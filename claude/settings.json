{
  "env": {
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1"
  },
  "permissions": {
    "allow": [
      "mcp__incident_io__*",
      "Skill(incident)",
      "Bash(rtk git log)",
      "Bash(rtk git log *)",
      "Bash(rtk git diff)",
      "Bash(rtk git diff *)",
      "Bash(rtk git status)",
      "Bash(rtk git status *)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "sh $HOME/.claude/statusline-command.sh"
  },
  "effortLevel": "medium",
  "theme": "auto",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  }
}
